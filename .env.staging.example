# Staging environment — copy to .env.staging (never commit secrets)
# Use with a dedicated Firebase staging project before production pilot.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Bootstrap administrators until custom claims are deployed
VITE_ADMIN_EMAILS=

# Staging must use Firestore (not local storage)
VITE_REPOSITORY_PROVIDER=firestore
