# Firebase — required for production authentication (M7)
# Copy to .env.local and fill in values from the Firebase console.
# Never commit real credentials.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated administrator emails (used when custom claims are not yet set).
# Example: admin@jih.org,ops@jih.org
VITE_ADMIN_EMAILS=

# Repository provider: local | firestore (requires Firebase configuration)
VITE_REPOSITORY_PROVIDER=local

# ─── KC-019 Digital Rafeeq Google Cloud TTS (server-only — never VITE_*) ───
# Prefer one of these for credentials (do not commit real values):
# GOOGLE_TTS_CREDENTIALS_JSON={"type":"service_account",...}
# GOOGLE_TTS_CREDENTIALS_JSON_BASE64=<base64 of the service account JSON>
# GOOGLE_APPLICATION_CREDENTIALS=C:\secrets\karkun-tts-sa.json
#
# Optional:
# TTS_CACHE_DIR=.tts-cache
# GOOGLE_TTS_VOICE=ur-IN-Chirp3-HD-Achird
