{
  "functions": {
    "api/tts.ts": {
      "includeFiles": "src/server/voice/**"
    },
    "api/stt.ts": {
      "includeFiles": "src/server/voice/**"
    },
    "api/rukn-claims-provision.ts": {
      "includeFiles": "src/server/ruknClaims/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
