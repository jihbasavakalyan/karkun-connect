rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdministrator() {
      return isSignedIn() && request.auth.token.role == 'administrator';
    }

    function isRukn() {
      return isSignedIn() && request.auth.token.role == 'rukn';
    }

    function ruknId() {
      return request.auth.token.ruknId;
    }

    function assignedToRukn(data) {
      return isRukn() && data.ruknId == ruknId();
    }

    function karkunAssignedToRukn(karkunId) {
      return isRukn() &&
        get(/databases/$(database)/documents/karkuns/$(karkunId)).data.assignedRuknId == ruknId();
    }

    // KC-0058 — critical collections: no client deletes (archive via update only).
    match /campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow create, update: if isAdministrator();
      allow delete: if false;
    }

    match /rukns/{docId} {
      allow read: if isAdministrator() || (isRukn() && docId == ruknId());
      allow create, update: if isAdministrator();
      allow delete: if false;
    }

    match /karkuns/{karkunId} {
      allow read: if isAdministrator() || (isRukn() && resource.data.assignedRuknId == ruknId());
      allow create, update: if isAdministrator();
      allow delete: if false;
    }

    match /connections/{assignmentId} {
      allow read: if isAdministrator() || assignedToRukn(resource.data);
      allow create: if isAdministrator() || assignedToRukn(request.resource.data);
      allow update: if isAdministrator() || assignedToRukn(resource.data);
      allow delete: if false;
    }

    // KC-0058 — activity append-only (create only).
    match /activityLogs/{entryId} {
      allow read: if isAdministrator() || (isRukn() && resource.data.ruknId == ruknId());
      allow create: if isAdministrator() || (isRukn() && request.resource.data.ruknId == ruknId());
      allow update, delete: if false;
    }

    // KC-0058 — connection ledger append-only.
    match /connectionLedger/{ledgerId} {
      allow read: if isAdministrator();
      allow create: if isAdministrator();
      allow update, delete: if false;
    }

    match /executions/{docId} {
      allow read: if isAdministrator() || isRukn();
      allow create: if isAdministrator() || (isRukn() && request.resource.data.ruknId == ruknId());
      allow update: if isAdministrator() || (isRukn() && resource.data.ruknId == ruknId());
      allow delete: if isAdministrator();
    }

    match /followUps/{followUpId} {
      allow read: if isAdministrator() || assignedToRukn(resource.data);
      allow create: if isAdministrator() || assignedToRukn(request.resource.data);
      allow update: if isAdministrator() || assignedToRukn(resource.data);
      allow delete: if isAdministrator();
    }

    match /communications/{docId} {
      allow read, write: if isAdministrator();
    }

    match /compliance/{docId} {
      allow read: if isAdministrator() || isRukn();
      allow write: if isAdministrator();
    }

    // KC-0056 — karkunCounter.nextKarkunNum is monotonic (stale clients cannot lag it).
    // KC-0058 — protect connectionMeta from delete.
    match /settings/{docId} {
      allow read: if isAdministrator();
      allow create: if isAdministrator();
      allow update: if isAdministrator() && (
        docId != 'karkunCounter' ||
        !('nextKarkunNum' in resource.data) ||
        request.resource.data.nextKarkunNum >= resource.data.nextKarkunNum
      );
      allow delete: if isAdministrator()
        && docId != 'karkunCounter'
        && docId != 'connectionMeta'
        && docId != 'karkunRequests';
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
